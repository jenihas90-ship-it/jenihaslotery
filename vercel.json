{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/dist/$1",
      "check": true
    },
    {
      "source": "/(.*)",
      "destination": "frontend/dist/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/admin/draw/run-now",
      "schedule": "0 0 * * *"
    }
  ]
}