PORT=5000
JWT_SECRET=change_this_super_secret_key_in_production
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=no-reply@yourlottery.com

# Africa's Talking SMS
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=LOTTERY

# Feature flags (set to 'true' to enable real sending)
ENABLE_EMAIL=false
ENABLE_SMS=false

# Admin seed
ADMIN_EMAIL=admin@lottery.com
ADMIN_PASSWORD=Admin1234!

NODE_ENV=development
